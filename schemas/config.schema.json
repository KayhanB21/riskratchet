{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KayhanB21/riskratchet/schemas/config.schema.json",
  "title": "riskratchet resolved config",
  "description": "Output of `riskratchet config show --json`.",
  "type": "object",
  "required": ["$schema", "version", "config_path", "config"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "config_path": { "type": "string" },
    "config": {
      "type": "object",
      "required": [
        "paths",
        "coverage",
        "coverage_map",
        "baseline",
        "fail_new_above",
        "fail_regression_above",
        "fail_existing_above",
        "fail_component_regression_above",
        "component_regression_gate",
        "allow_missing_coverage",
        "auto_coverage",
        "coverage_cache",
        "test_command",
        "missing_coverage",
        "churn_window_days",
        "include",
        "exclude",
        "allow",
        "weights",
        "groups"
      ],
      "additionalProperties": false,
      "properties": {
        "paths": { "type": "array", "items": { "type": "string" } },
        "coverage": { "type": ["string", "null"] },
        "coverage_map": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "baseline": { "type": "string" },
        "fail_new_above": { "type": "number" },
        "fail_regression_above": { "type": "number" },
        "fail_existing_above": { "type": ["number", "null"] },
        "fail_component_regression_above": { "type": "number" },
        "component_regression_gate": { "type": "boolean" },
        "allow_missing_coverage": { "type": "boolean" },
        "auto_coverage": { "type": "boolean" },
        "coverage_cache": { "type": "string" },
        "test_command": { "type": "string" },
        "missing_coverage": { "enum": ["pessimistic", "skip", "zero"] },
        "churn_window_days": { "type": "integer", "minimum": 1 },
        "include": { "type": "array", "items": { "type": "string" } },
        "exclude": { "type": "array", "items": { "type": "string" } },
        "allow": { "type": "array", "items": { "type": "string" } },
        "weights": {
          "type": "object",
          "required": [
            "coverage_gap",
            "structural_complexity",
            "branch_gap",
            "churn",
            "public_surface",
            "sprawl"
          ],
          "additionalProperties": false,
          "properties": {
            "coverage_gap": { "type": "number", "minimum": 0 },
            "structural_complexity": { "type": "number", "minimum": 0 },
            "branch_gap": { "type": "number", "minimum": 0 },
            "churn": { "type": "number", "minimum": 0 },
            "public_surface": { "type": "number", "minimum": 0 },
            "sprawl": { "type": "number", "minimum": 0 }
          }
        },
        "groups": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
