{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KayhanB21/riskratchet/schemas/diff.schema.json",
  "title": "riskratchet baseline diff",
  "description": "Output of `riskratchet diff --json`.",
  "type": "object",
  "required": ["$schema", "version", "summary", "entries"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "summary": {
      "type": "object",
      "required": [
        "regressed",
        "component_regressed",
        "improved",
        "new",
        "removed",
        "moved",
        "ambiguous_rename",
        "unchanged",
        "groups"
      ],
      "additionalProperties": false,
      "properties": {
        "regressed": { "type": "integer", "minimum": 0 },
        "component_regressed": { "type": "integer", "minimum": 0 },
        "improved": { "type": "integer", "minimum": 0 },
        "new": { "type": "integer", "minimum": 0 },
        "removed": { "type": "integer", "minimum": 0 },
        "moved": { "type": "integer", "minimum": 0 },
        "ambiguous_rename": { "type": "integer", "minimum": 0 },
        "unchanged": { "type": "integer", "minimum": 0 },
        "groups": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "regressed",
              "component_regressed",
              "improved",
              "new",
              "removed",
              "moved",
              "ambiguous_rename",
              "unchanged"
            ],
            "additionalProperties": false,
            "properties": {
              "regressed": { "type": "integer", "minimum": 0 },
              "component_regressed": { "type": "integer", "minimum": 0 },
              "improved": { "type": "integer", "minimum": 0 },
              "new": { "type": "integer", "minimum": 0 },
              "removed": { "type": "integer", "minimum": 0 },
              "moved": { "type": "integer", "minimum": 0 },
              "ambiguous_rename": { "type": "integer", "minimum": 0 },
              "unchanged": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "qualname",
          "group",
          "status",
          "current_score",
          "previous_score",
          "delta",
          "previous_path",
          "previous_qualname",
          "reason",
          "previous_targets",
          "match_confidence"
        ],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "qualname": { "type": "string" },
          "group": { "type": ["string", "null"] },
          "status": {
            "enum": [
              "regressed",
              "component_regressed",
              "improved",
              "new",
              "removed",
              "moved",
              "ambiguous_rename",
              "unchanged"
            ]
          },
          "current_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "previous_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "delta": { "type": ["number", "null"] },
          "previous_path": { "type": ["string", "null"] },
          "previous_qualname": { "type": ["string", "null"] },
          "reason": { "type": "string" },
          "previous_targets": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "qualname"],
              "additionalProperties": false,
              "properties": {
                "path": { "type": "string" },
                "qualname": { "type": "string" }
              }
            }
          },
          "match_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "source_url": { "type": "string", "description": "Optional blob URL (P10, since 0.2.8); emitted when --repo-url and --commit-ref are passed and the entry has a current snapshot." }
        }
      }
    }
  }
}
